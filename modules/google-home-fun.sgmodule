#!name=GoogleHomeFun
#!desc=为 Google 首页添加一个明显且俏皮的横幅
#!arguments=文案:今天也要快乐摸鱼

[Script]
google.home.fun = type=http-response, pattern=^https:\/\/www\.google\.com\/(\?.*)?$, script-path=./google-home-fun.js, requires-body=true, max-size=2097152, argument="{\"message\":\"{{{文案}}}\"}"

[MITM]
hostname = %APPEND% www.google.com
